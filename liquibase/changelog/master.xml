<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.26.xsd">

    <changeSet id="001_create_users_table" author="devops">
        <createTable tableName="USERS" schemaName="ADMIN">
            <column name="USER_ID" type="NUMBER(10)" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="USERNAME" type="VARCHAR2(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="EMAIL" type="VARCHAR2(100)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="CREATED_AT" type="TIMESTAMP" defaultValue="SYSTIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <rollback>
            <dropTable tableName="USERS" schemaName="ADMIN"/>
        </rollback>
    </changeSet>

    <changeSet id="002_create_users_sequence" author="devops">
        <createSequence sequenceName="USER_SEQ" schemaName="ADMIN" startValue="1" incrementBy="1"/>
        <rollback>
            <dropSequence sequenceName="USER_SEQ" schemaName="ADMIN"/>
        </rollback>
    </changeSet>

    <changeSet id="003_create_user_trigger" author="devops">
        <sql>
            CREATE OR REPLACE TRIGGER ADMIN.USER_ID_TRIGGER
            BEFORE INSERT ON ADMIN.USERS
            FOR EACH ROW
            BEGIN
                IF :NEW.USER_ID IS NULL THEN
                    SELECT USER_SEQ.NEXTVAL INTO :NEW.USER_ID FROM DUAL;
                END IF;
            END;
            /
        </sql>
        <rollback>
            <dropTrigger triggerName="USER_ID_TRIGGER" schemaName="ADMIN"/>
        </rollback>
    </changeSet>

    <changeSet id="004_create_audit_table" author="devops">
        <createTable tableName="AUDIT_LOG" schemaName="ADMIN">
            <column name="AUDIT_ID" type="NUMBER(20)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="TABLE_NAME" type="VARCHAR2(30)">
                <constraints nullable="false"/>
            </column>
            <column name="OPERATION" type="VARCHAR2(10)">
                <constraints nullable="false"/>
            </column>
            <column name="CHANGED_BY" type="VARCHAR2(50)">
                <constraints nullable="false"/>
            </column>
            <column name="CHANGED_AT" type="TIMESTAMP" defaultValue="SYSTIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <rollback>
            <dropTable tableName="AUDIT_LOG" schemaName="ADMIN"/>
        </rollback>
    </changeSet>

    <changeSet id="005_add_users_index" author="devops">
        <createIndex tableName="USERS" schemaName="ADMIN" indexName="IDX_USERS_EMAIL">
            <column name="EMAIL"/>
        </createIndex>
        <rollback>
            <dropIndex indexName="IDX_USERS_EMAIL" schemaName="ADMIN"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
