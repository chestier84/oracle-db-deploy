[sqlfluff]
dialect = oracle
max_line_length = 120
indent_unit = space
indent_size = 4
runaway_limit = 10
ignore_templated_sections = true

[sqlfluff:indentation]
indented_joins = false
indented_using_on = true
template_block_starts = block
template_block_ends = endblock

[sqlfluff:layout:type:comma]
spacing_before = touch
spacing_after = single

[sqlfluff:core]
allow_implicit_aliasing = false
ignore = parsing,templating

[sqlfluff:rules]
# Reglas de estilo que se aplican
max_line_length = 120
indent_unit = space
indent_size = 4

# Reglas deshabilitadas que podrían causar conflictos
exclude_rules = 
    L009,
    L020,
    L034,
    L052

# Reglas de seguridad y mejores prácticas habilitadas
rules =
    L001,
    L002,
    L003,
    L004,
    L005,
    L006,
    L007,
    L008,
    L010,
    L011,
    L012,
    L013,
    L014,
    L015,
    L016,
    L017,
    L018,
    L019,
    L021,
    L022,
    L023,
    L024,
    L025,
    L026,
    L027,
    L028,
    L029,
    L030,
    L031,
    L032,
    L033,
    L035,
    L036,
    L037,
    L038,
    L039,
    L040,
    L041,
    L042,
    L043,
    L044,
    L045,
    L046,
    L047,
    L048,
    L049,
    L050,
    L051,
    L053,
    L054,
    L055,
    L056,
    L057,
    L058,
    L059,
    L060,
    L061,
    L062,
    L063

[sqlfluff:rules:core]
operator_new_lines = before

[sqlfluff:rules:L010]
# Keywords should be capitalized
capitalisation_policy = consistent

[sqlfluff:rules:L014]
# Unquoted identifiers should be lowercase
capitalisation_policy = lower

[sqlfluff:rules:L030]
# Null and boolean literals should be lowercase
capitalisation_policy = lower

[sqlfluff:rules:L040]
# Null and boolean literals should be lowercase
capitalisation_policy = lower
